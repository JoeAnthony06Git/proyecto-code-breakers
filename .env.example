# API
PORT=8787
CLIENT_ORIGIN=http://127.0.0.1:5173

# Demo mode is enabled automatically when USE_SUPABASE is not true.
# Use local file persistence for hackathon demos without external services.
USE_SUPABASE=false
SESSION_SECRET=replace-with-a-long-random-string

# Supabase Auth + CRM storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini response enhancement, optional.
# The core RAG guardrails work without this key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
